# HAL9000 — Environment Variables
# Copy to .env and fill in your keys

# ═══════════════════════════════════════════════
# FREE MODE — zero API keys, fully local
# Set this to true and skip everything below.
# Requires: Ollama installed + a model pulled (ollama pull llama3.1)
# ═══════════════════════════════════════════════
# FREE_MODE=true

# ═══════════════════════════════════════════════
# AI Provider (brain)
# ═══════════════════════════════════════════════
# Options: "openai", "anthropic", "gemini", "ollama"
# In FREE_MODE, this is overridden to "ollama"
AI_PROVIDER=openai

# OpenAI (GPT-4o brain + Whisper STT)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o            # optional override

# Anthropic (Claude — only if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (only if AI_PROVIDER=gemini)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# Ollama (local LLM — only if AI_PROVIDER=ollama or FREE_MODE=true)
# OLLAMA_MODEL=llama3.1           # any model: llama3.1, mistral, phi3, codellama
# OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════════════
# STT Provider (speech-to-text)
# ═══════════════════════════════════════════════
# Options: "whisper_api" (OpenAI, paid), "faster_whisper" (local, free)
# In FREE_MODE, this is overridden to "faster_whisper"
# STT_PROVIDER=whisper_api
# WHISPER_MODEL_SIZE=base          # faster-whisper model: tiny, base, small, medium

# ═══════════════════════════════════════════════
# TTS Provider (text-to-speech)
# ═══════════════════════════════════════════════
# Options: "edge" (free, fast), "elevenlabs" (paid, best), "local" (XTTS, slow)
TTS_PROVIDER=edge
EDGE_VOICE=en-US-ChristopherNeural   # deep calm male voice (free)

# ElevenLabs (only if TTS_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=...

# ═══════════════════════════════════════════════
# Context & Generation
# ═══════════════════════════════════════════════
# CONTEXT_MAX_TOKENS=16000       # max tokens in conversation history
# TOOL_RESULT_MAX_CHARS=1500     # truncate old tool results beyond this
# MAX_TOKENS=1024                # max tokens per LLM response

# ═══════════════════════════════════════════════
# Co-Work (background tasks, agents)
# ═══════════════════════════════════════════════
# TASK_TIMEOUT=600               # background task timeout (seconds)
# MAX_CONCURRENT_TASKS=2         # max parallel background tasks
# MAX_AGENTS=4                   # max orchestrated agents

# ═══════════════════════════════════════════════
# Tuning
# ═══════════════════════════════════════════════
FRAME_INTERVAL=2.0              # seconds between webcam samples
MIC_RECORD_SECONDS=5            # max recording duration per utterance
SILENCE_THRESHOLD=500           # audio amplitude below this = silence
HAL_NAME=HAL                    # change if you want a different wake name
# SERVER_PORT=9000               # web server port
# HAL_HOST=127.0.0.1             # bind address (0.0.0.0 for LAN)
