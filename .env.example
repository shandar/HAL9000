# HAL9000 — Environment Variables
# Copy to .env and fill in your keys

# AI Provider: "openai", "anthropic", or "gemini"
AI_PROVIDER=openai

# OpenAI (GPT-4o brain + Whisper STT — always needed for STT)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o            # optional override

# Anthropic (Claude — only needed if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (only needed if AI_PROVIDER=gemini)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# TTS Provider: "edge" (free, fast), "elevenlabs" (paid, best), or "local" (XTTS, slow)
TTS_PROVIDER=edge
EDGE_VOICE=en-US-ChristopherNeural   # deep calm male voice (free)

# ElevenLabs (only needed if TTS_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=...       # Find a deep calm baritone in ElevenLabs library

# Wake word detection (say "Hey HAL" to activate)
WAKE_WORD_ENABLED=true          # set to false for always-listening mode

# Context window management
# CONTEXT_MAX_TOKENS=16000       # max tokens to keep in conversation history
# TOOL_RESULT_MAX_CHARS=1500     # truncate old tool results beyond this

# Optional tuning
FRAME_INTERVAL=2.0              # seconds between webcam samples sent to AI
MIC_RECORD_SECONDS=5            # max recording duration per utterance
SILENCE_THRESHOLD=500           # audio amplitude below this = silence
HAL_NAME=HAL                    # change if you want a different wake name
